{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@sanctum/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src"]
}
