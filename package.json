{
  "name": "sanctum",
  "private": true,
  "version": "1.0.0",
  "description": "Sanctum — church facility-rental platform. Open doors. Stronger communities.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:web": "npm run build --workspace=@sanctum/web",
    "build:shared": "npm run build --workspace=@sanctum/shared",
    "dev": "wrangler dev",
    "dev:web": "npm run dev --workspace=@sanctum/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dry": "npm run build && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0",
    "@cloudflare/workers-types": "^4.20241127.0"
  },
  "engines": {
    "node": ">=20"
  }
}
